# Database connection string
DATABASE_URI=postgres://postgres:postgres@localhost:5432/your-sofia

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE_CHANGE_IN_PRODUCTION

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Default sender details for transactional emails
EMAIL_FROM_NAME=Твоята София
EMAIL_FROM_ADDRESS=no-reply@your.sofia.bg

# Optional SMTP settings for sending real emails in all environments.
# If omitted, Payload uses Ethereal test inboxes in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE_CHANGE_IN_PRODUCTION

# Used to validate preview requests
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE_CHANGE_IN_PRODUCTION

# Node environment (development, production)
NODE_ENV=development

# Server port
PORT=3000

# Upstream OboApp base URL used for updates proxy routes.
# Expected to point to the OboApp public v1 API base (for example: https://api.oboapp.online/v1)
OBOAPP_UPDATES_BASE_URL=https://api.oboapp.online/v1

# API key for OboApp public API (sent as X-Api-Key upstream)
OBOAPP_API_KEY=YOUR_OBOAPP_API_KEY

# Inspectorat GPS API configuration
INSPECTORAT_GPS_API_BASE_URL=https://gps.inspectorat-so.org/api/v1
INSPECTORAT_GPS_API_KEY=YOUR_INSPECTORAT_GPS_API_KEY
