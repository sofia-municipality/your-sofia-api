# Single shared app environment for BOTH the staging and production stacks.
# Copy to `.env` (docker/infrastructure/.env) and fill in real values — the shared
# docker-stack.yml loads it via `env_file` for whichever stack it's deployed as, and
# diun/run-diun.sh sources it for GHCR_USERNAME / GHCR_PASSWORD.

# GHCR pull credentials for diun — a GitHub username + a PAT with `read:packages`.
# run-diun.sh exports these; docker-compose.yml maps them into DIUN_REGOPTS_GHCR_*.
GHCR_USERNAME=your-github-username
GHCR_PASSWORD=CHANGE_ME_GHCR_PAT_READ_PACKAGES

DATABASE_URI=postgres://postgres:CHANGE_ME@host.docker.internal:5432/your-sofia

NODE_ENV=production
NEXT_PUBLIC_SERVER_URL=https://your.sofia.bg

PAYLOAD_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS
CRON_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS
PREVIEW_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS

OBOAPP_UPDATES_BASE_URL=https://oboapp.online/api/v1
OBOAPP_API_KEY=CHANGE_ME_OBOAPP_API_KEY

INSPECTORAT_GPS_API_BASE_URL=https://gps.inspectorat-so.org/api/v1
INSPECTORAT_GPS_API_KEY=CHANGE_ME_INSPECTORAT_GPS_API_KEY

EMAIL_FROM_NAME=Твоята София
EMAIL_FROM_ADDRESS=no-reply@your.sofia.bg
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
